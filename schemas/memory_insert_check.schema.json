{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryInsertCheck",
  "type": "object",
  "required": [
    "insert",
    "reason",
    "deduplicate_with"
  ],
  "additionalProperties": false,
  "properties": {
    "insert": {
      "type": "boolean"
    },
    "reason": {
      "type": "string"
    },
    "deduplicate_with": {
      "type": [
        "string",
        "null"
      ]
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
